@model dynamic
@{
    Layout = "_Layout";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="welcome-bar">
    <h1>System Administration Console</h1>
    <p>Monitor security parameters, user locks, and core audit trail entries</p>
</div>

<div class="summary-cards">
    <div class="summary-card">
        <div class="card-label">Total Provisioned Users</div>
        <div class="card-value">@ViewBag.TotalUsers</div>
        <div class="card-sub">All departments</div>
    </div>
    <div class="summary-card">
        <div class="card-label">Active Session Logs</div>
        <div class="card-value">@ViewBag.ActiveUsers</div>
        <div class="card-sub">Active status</div>
    </div>
    <div class="summary-card">
        <div class="card-label">Locked Accounts</div>
        <div class="card-value" style="color: var(--color-danger);">@ViewBag.LockedUsers</div>
        <div class="card-sub">Awaiting IT action</div>
    </div>
    <div class="summary-card">
        <div class="card-label">Recent Activities (7d)</div>
        <div class="card-value">@ViewBag.RecentActivityCount</div>
        <div class="card-sub">System-wide logs</div>
    </div>
</div>

<div class="two-col-grid" style="margin-top: 24px;">
    <div class="card">
        <div class="section-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
            <h3>Recent User Logins</h3>
            <a href="/Admin/Users" style="font-size: 13px; color: var(--color-primary); text-decoration: none; font-weight: 500;">Manage Users</a>
        </div>
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Module</th>
                        <th>Timestamp</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.RecentLogins != null && ViewBag.RecentLogins.Count > 0)
                    {
                        foreach (var log in ViewBag.RecentLogins)
                        {
                            <tr>
                                <td><strong>@log.User</strong></td>
                                <td>@log.Module</td>
                                <td style="font-size: 12px; color: var(--text-tertiary);">@log.Timestamp</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" style="text-align: center; color: var(--text-tertiary); padding: 24px;">No recent login logs.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="section-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
            <h3>System Activity Trail</h3>
            <a href="/Admin/ActivityLog" style="font-size: 13px; color: var(--color-primary); text-decoration: none; font-weight: 500;">Audit Logs</a>
        </div>

        @if (ViewBag.RecentActivities != null && ViewBag.RecentActivities.Count > 0)
        {
            foreach (var act in ViewBag.RecentActivities)
            {
                <div class="activity-item" style="padding: 12px 0; border-bottom: 1px solid var(--color-border); font-size: 13px;">
                    <div style="display: flex; justify-content: space-between; font-weight: 600;">
                        <span>@act.User</span>
                        <span style="font-size: 11px; color: var(--text-tertiary); font-weight: normal;">@act.Timestamp</span>
                    </div>
                    <div style="color: var(--text-secondary); margin-top: 4px;">@act.Action - <span style="font-size: 12px; color: var(--text-tertiary);">@act.Details</span></div>
                </div>
            }
        }
        else
        {
            <div style="text-align: center; color: var(--text-tertiary); padding: 24px;">No recent activities logged.</div>
        }
    </div>
</div>
