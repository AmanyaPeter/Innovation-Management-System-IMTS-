@model List<Imts.Web.Services.Category>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Configuration Categories";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success" style="color: var(--color-success); background-color: #EBFDF2; border: 1px solid #DCFCE7; padding: 12px; border-radius: var(--radius-sm); margin-bottom: 20px; font-size: 14px;">
        @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger" style="color: var(--color-danger); background-color: #FDF2F2; border: 1px solid #FDE8E8; padding: 12px; border-radius: var(--radius-sm); margin-bottom: 20px; font-size: 14px;">
        @TempData["ErrorMessage"]
    </div>
}

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 24px; align-items: start;">
    <!-- Category CRUD Table -->
    <div class="card" style="padding: 24px; border: 1px solid var(--color-border); border-radius: var(--radius-md); background-color: var(--color-white);">
        <h3 style="margin-top: 0; color: var(--color-primary); margin-bottom: 20px;">System Categories</h3>

        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Category Name</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Count > 0)
                    {
                        foreach (var cat in Model)
                        {
                            <tr>
                                <td><strong>@cat.Name</strong></td>
                                <td style="font-size: 13px; color: var(--text-secondary);">@cat.Description</td>
                                <td>
                                    @if (cat.IsActive)
                                    {
                                        <span class="badge badge-approved">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-draft">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div style="display: flex; gap: 8px;">
                                        <!-- Toggle Status -->
                                        <form asp-controller="Review" asp-action="ToggleCategoryStatus" asp-route-id="@cat.Id" method="post" style="display:inline;">
                                            <input type="hidden" name="name" value="@cat.Name">
                                            <input type="hidden" name="description" value="@cat.Description">
                                            <input type="hidden" name="isActive" value="@cat.IsActive.ToString().ToLower()">
                                            <button type="submit" class="btn" style="padding: 4px 8px; font-size: 11px; background-color: var(--color-surface-muted); border: 1px solid var(--color-border); border-radius: var(--radius-sm); cursor: pointer;">
                                                @(cat.IsActive ? "Deactivate" : "Activate")
                                            </button>
                                        </form>

                                        <!-- Delete -->
                                        <form asp-controller="Review" asp-action="DeleteCategory" asp-route-id="@cat.Id" method="post" onsubmit="return confirm('Are you sure you want to delete this category?');" style="display:inline;">
                                            <button type="submit" class="btn" style="padding: 4px 8px; font-size: 11px; background-color: #FDF2F2; border: 1px solid #FDE8E8; color: var(--color-danger); border-radius: var(--radius-sm); cursor: pointer;">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" style="text-align: center; color: var(--text-tertiary); padding: 24px;">No categories configured.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Create Category Form -->
    <div class="card" style="padding: 24px; border: 1px solid var(--color-border); border-radius: var(--radius-md); background-color: var(--color-white);">
        <h3 style="margin-top: 0; color: var(--color-primary); margin-bottom: 16px; font-size: 18px;">Configure Category</h3>

        <form asp-controller="Review" asp-action="CreateCategory" method="post">
            <div class="form-group" style="margin-bottom: 16px;">
                <label for="name" style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 14px;">Category Name</label>
                <input type="text" id="name" name="name" required placeholder="e.g. FinTech" style="width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--radius-sm);">
            </div>

            <div class="form-group" style="margin-bottom: 20px;">
                <label for="description" style="display: block; margin-bottom: 6px; font-weight: 600; font-size: 14px;">Description</label>
                <textarea id="description" name="description" placeholder="Describe the purpose of this innovation category..." style="width: 100%; min-height: 80px; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--radius-sm); font-size: 13px;"></textarea>
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 10px; font-weight: 600; background-color: var(--color-primary); color: white; border: none; border-radius: var(--radius-sm); cursor: pointer;">Create Category</button>
        </form>
    </div>
</div>
