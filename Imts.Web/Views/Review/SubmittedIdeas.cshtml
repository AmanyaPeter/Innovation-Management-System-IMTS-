@model List<Imts.Web.Services.IdeaResponse>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Submitted Ideas";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success" style="color: var(--color-success); background-color: #EBFDF2; border: 1px solid #DCFCE7; padding: 12px; border-radius: var(--radius-sm); margin-bottom: 20px; font-size: 14px;">
        @TempData["SuccessMessage"]
    </div>
}

<div class="card" style="padding: 24px; border: 1px solid var(--color-border); border-radius: var(--radius-md); background-color: var(--color-white);">
    <h3 style="margin-top: 0; color: var(--color-primary); margin-bottom: 20px;">Master Innovation Submissions</h3>

    <!-- Filters and search bar -->
    <div style="display: flex; gap: 16px; margin-bottom: 24px; align-items: center; flex-wrap: wrap;">
        <div style="flex: 1; min-width: 250px; position: relative;">
            <input type="text" id="reviewSearch" placeholder="Search by title, submitter, or keyword..." style="width: 100%; padding: 10px 10px 10px 36px; border: 1px solid var(--color-border); border-radius: var(--radius-sm);">
            <i data-lucide="search" style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); width: 18px; height: 18px; color: var(--text-tertiary);"></i>
        </div>
        <div style="width: 180px;">
            <select id="deptFilter" style="width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--radius-sm);">
                <option value="">All Departments</option>
                <option value="information technology">Information Technology</option>
                <option value="finance">Finance</option>
                <option value="operations">Operations</option>
                <option value="innovation team">Innovation Team</option>
            </select>
        </div>
        <div style="width: 180px;">
            <select id="stageFilter" style="width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--radius-sm);">
                <option value="">All Stages</option>
                <option value="submitted">Submitted</option>
                <option value="concept development">Concept Development</option>
                <option value="experimentation">Experimentation</option>
                <option value="deployment">Deployment</option>
                <option value="closed">Closed</option>
            </select>
        </div>
    </div>

    <div class="table-container">
        <table class="data-table" id="submittedIdeasTable">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Submitter</th>
                    <th>Department</th>
                    <th>Stage</th>
                    <th>Status</th>
                    <th>Submitted Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Count > 0)
                {
                    foreach (var idea in Model)
                    {
                        <tr data-dept="@idea.Department.ToLower()" data-stage="@idea.Stage.ToLower()" data-text="@idea.Title.ToLower() @idea.SubmitterName.ToLower() @idea.Category.ToLower()">
                            <td><a href="/Ideas/Details/@idea.Id" style="color: var(--color-primary); text-decoration: none; font-weight: 600;">@idea.Title</a><div style="font-size: 11px; color: var(--text-tertiary); margin-top: 2px;">@idea.Category</div></td>
                            <td>@idea.SubmitterName</td>
                            <td>@idea.Department</td>
                            <td><span style="font-weight: 500;">@idea.Stage</span></td>
                            <td>@await Component.InvokeAsync("StatusBadge", new { status = idea.Status })</td>
                            <td>@idea.DateSubmitted</td>
                            <td>
                                <a href="/Review/ReviewIdea/@idea.Id" class="btn btn-primary" style="padding: 6px 12px; font-size: 12px; font-weight: 600; text-decoration: none; border-radius: var(--radius-sm); background-color: var(--color-primary); color: white; display: inline-block;">Review</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" style="text-align: center; color: var(--text-tertiary); padding: 32px;">No idea submissions found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        const reviewSearch = document.getElementById('reviewSearch');
        const deptFilter = document.getElementById('deptFilter');
        const stageFilter = document.getElementById('stageFilter');
        const rows = document.querySelectorAll('#submittedIdeasTable tbody tr');

        function filterReviewTable() {
            const query = reviewSearch.value.toLowerCase().trim();
            const dept = deptFilter.value.toLowerCase();
            const stage = stageFilter.value.toLowerCase();

            rows.forEach(row => {
                if (row.cells.length < 5) return;
                const text = row.getAttribute('data-text') || '';
                const rowDept = row.getAttribute('data-dept') || '';
                const rowStage = row.getAttribute('data-stage') || '';

                const matchesSearch = text.includes(query);
                const matchesDept = dept === '' || rowDept === dept;
                const matchesStage = stage === '' || rowStage === stage;

                if (matchesSearch && matchesDept && matchesStage) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        if (reviewSearch && deptFilter && stageFilter) {
            reviewSearch.addEventListener('input', filterReviewTable);
            deptFilter.addEventListener('change', filterReviewTable);
            stageFilter.addEventListener('change', filterReviewTable);
        }
    </script>
}
