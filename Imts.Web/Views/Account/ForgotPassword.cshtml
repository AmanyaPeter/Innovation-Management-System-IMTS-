@model dynamic
@{
    Layout = "_Layout";
    ViewData["Title"] = "Forgot Password";
    ViewData["BodyClass"] = "login-page";
}

<div class="login-card" style="margin: 80px auto; max-width: 450px;">
    <div class="logo">
        <img src="~/favicon.ico" alt="Bank of Uganda" style="width: 80px; height: 80px;">
    </div>
    <h1 class="system-title">Password Recovery</h1>
    <p class="system-subtitle" style="margin-bottom: 24px;">Enter your email to receive a password reset link</p>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success" style="color: var(--color-success); background-color: #EBFDF2; border: 1px solid #DCFCE7; padding: 16px; border-radius: var(--radius-sm); margin-bottom: 24px; font-size: 14px; text-align: center;">
            @TempData["SuccessMessage"]
            <div style="margin-top: 12px;">
                <a href="/Account/Login" class="btn btn-primary" style="display: inline-block; padding: 8px 16px; background-color: var(--color-primary); color: white; text-decoration: none; border-radius: var(--radius-sm); font-weight: 500;">Back to Log in</a>
            </div>
        </div>
    }
    else
    {
        <form asp-controller="Account" asp-action="ForgotPassword" method="post">
            <div class="form-group" style="margin-bottom: 20px;">
                <label for="email" style="display: block; margin-bottom: 6px; font-weight: 500;">Email Address</label>
                <input type="email" id="email" name="email" class="form-control" placeholder="username@bou.or.ug" required style="width: 100%; padding: 10px; border: 1px solid var(--color-border); border-radius: var(--radius-sm);">
            </div>

            <button type="submit" class="login-btn" style="width: 100%; padding: 12px; background-color: var(--color-primary); color: var(--color-white); border: none; border-radius: var(--radius-sm); font-size: 15px; font-weight: 600; cursor: pointer; transition: background-color var(--transition-fast);">Send Reset Link</button>

            <div style="text-align: center; margin-top: 16px;">
                <a href="/Account/Login" style="color: var(--color-primary); text-decoration: none; font-size: 14px; font-weight: 500;">Back to Log in</a>
            </div>
        </form>
    }
</div>

<div class="footer" style="text-align: center; margin-top: 40px; font-size: 13px; color: var(--text-tertiary);">&copy; @DateTime.Now.Year Bank of Uganda. All rights reserved.</div>
