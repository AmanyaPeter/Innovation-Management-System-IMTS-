@model dynamic
@{
    Layout = "_Layout";
    ViewData["Title"] = "Log in";
    ViewData["BodyClass"] = "login-page";
}

<div class="login-card">
    <div class="logo">
        <img src="/favicon.ico" alt="Bank of Uganda" style="width: 80px; height: 80px;">
    </div>
    <h1 class="system-title">Innovation Management System</h1>
    <p class="system-subtitle">Submit, manage and track innovation ideas</p>

    <form asp-controller="Account" asp-action="Login" method="post">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger" style="color: var(--color-danger); background-color: #FDF2F2; border: 1px solid #FDE8E8; padding: 12px; border-radius: var(--radius-sm); margin-bottom: 16px; font-size: 14px;">
                <div asp-validation-summary="ModelOnly"></div>
            </div>
        }

        <div class="form-group">
            <label for="username">Username / Email</label>
            <input type="text" id="username" name="username" class="form-control" placeholder="Enter your username or email" required autocomplete="username">
        </div>

        <div class="form-group">
            <label for="password">Password</label>
            <div class="password-wrapper">
                <input type="password" id="password" name="password" class="form-control" placeholder="Enter your password" required autocomplete="current-password">
                <button type="button" class="toggle-password" id="togglePassword" aria-label="Show password">
                    <i data-lucide="eye" style="width:18px;height:18px;"></i>
                </button>
            </div>
        </div>

        <div class="form-options" style="display: flex !important; justify-content: space-between !important; align-items: center !important; width: 100% !important; margin-bottom: 24px;">
            <label class="remember-me" style="display: flex !important; align-items: center !important; gap: 6px !important; margin: 0 !important;">
                <input type="checkbox" checked style="width: auto !important; height: auto !important;"> Remember me
            </label>
            <a href="/Account/ForgotPassword" class="forgot-link" style="color: var(--color-primary) !important; font-size: 13px !important; text-decoration: none !important;">Forgot password?</a>
        </div>

        <button type="submit" class="login-btn">Log in</button>
    </form>

    <div class="disclaimer">
        <strong>Confidentiality Notice:</strong> This system is for authorised users only. All activities are monitored and logged. Unauthorised access or use is strictly prohibited and may result in disciplinary action.
    </div>
</div>

<div class="footer">&copy; @DateTime.Now.Year Bank of Uganda. All rights reserved.</div>

@section Scripts {
    <script>
        const togglePassword = document.querySelector('#togglePassword');
        const password = document.querySelector('#password');
        togglePassword.addEventListener('click', function (e) {
            const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
            password.setAttribute('type', type);
            const icon = this.querySelector('i');
            if (type === 'text') {
                icon.setAttribute('data-lucide', 'eye-off');
            } else {
                icon.setAttribute('data-lucide', 'eye');
            }
            lucide.createIcons();
        });
    </script>
}
